#include <stdio.h>

int main()
{
    int a;
    scanf("%d", &a);
    for (int i = 1; i < a+1; i++)
    {
        for (int c = 0; c < a - i; c++)
        {
            printf(" ");
        }
        for (int j = 0; j < i ; j++)
        {
            printf("*");
        }
        printf("\n");
    }
    return 0;
}
